generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  IN_REVIEW
  APPROVED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum ProjectRisk {
  LOW
  MEDIUM
  HIGH
}

model Project {
  id          String        @id @default(uuid())
  name        String
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  totalBudget Float
  description String
  status      ProjectStatus @default(IN_REVIEW)
  risk        ProjectRisk   @default(LOW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
