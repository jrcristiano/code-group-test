NODE_ENV=development
PORT=3001

# PostgreSQL para API rodando no host com o banco do Docker publicado em 5433.
# Dentro do Docker Compose, DATABASE_URL é sobrescrita para usar o host interno
# `database:5432`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres?schema=public

# Segurança
CORS_ORIGINS=http://localhost:5173
SWAGGER_ENABLED=true
# Mantém os curls do Swagger corretos tanto direto quanto via proxy /api.
SWAGGER_SERVER=.

# Rate Limiting (requisições por janela)
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# Database Pool (postgresql apenas)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE_TIMEOUT=30000

# Payload
MAX_PAYLOAD_SIZE=1mb
