# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5433

# ============================================
# API (produção)
# ============================================
NODE_ENV=production
API_PORT=8000
API_INTERNAL_PORT=3000

# ============================================
# API (desenvolvimento)
# ============================================
API_DEV_PORT=3001
API_DEV_INTERNAL_PORT=3001

# ============================================
# Frontend
# ============================================
UI_PORT=5173
UI_DEV_PORT=5173

# ============================================
# CORS (origens permitidas, separadas por vírgula)
# ============================================
CORS_ORIGINS=http://localhost:5173

# ============================================
# Swagger
# ============================================
SWAGGER_ENABLED=true
# URL relativa ao documento OpenAPI: funciona em /docs e /api/docs.
SWAGGER_SERVER=.

# ============================================
# Rate Limiting (requisições por janela)
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# ============================================
# Database Pool (PostgreSQL)
# ============================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE_TIMEOUT=30000

# ============================================
# Payload
# ============================================
MAX_PAYLOAD_SIZE=1mb

# ============================================
# Vite (build argument para produção)
# ============================================
VITE_API_URL=/api
